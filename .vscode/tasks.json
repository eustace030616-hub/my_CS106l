{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run (current file)",
            "type": "shell",
            "command": "make",
            "args": ["${fileBasenameNoExtension}"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "focus": true
            }
        }
    ]
}
